{
   "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
   "name": "microsoft.com/azure-devops",
   "description": "Azure DevOps MCP Server - access work items, pull requests, repositories, pipelines, and more.",
   "repository": {
     "url": "https://github.com/microsoft/azure-devops-mcp",
     "source": "github"
   },
   "version": "2.5.0",
   "packages": [
     {
       "registryType": "npm",
       "identifier": "@azure-devops/mcp",
       "version": "2.5.0",
       "runtimeHint": "npx",
       "packageArguments": [
         {
           "type": "positional",
           "value": "{organization}",
           "variables": {
             "organization": {
               "description": "Nome da organização Azure DevOps (ex: solidestech)",
               "isRequired": true,
               "placeholder": "solidestech"
             }
           }
         }
       ],
       "transport": {
         "type": "stdio"
       },
       "environmentVariables": [
         {
           "name": "AZURE_DEVOPS_EXT_PAT",
           "description": "Personal Access Token do Azure DevOps com permissão de leitura",
           "isRequired": true,
           "isSecret": true
         }
       ]
     }
   ]
 }